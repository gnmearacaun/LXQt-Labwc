#########
# Autostart Applications started here aren't closed by `lxqt-leave --logout` and settings can be lost
#########

# Screen off after x seconds 
swayidle -w timeout 180 'wlopm --off \*' resume 'wlopm --on \*' &
# Warmer color temperature
gammastep -O 3350 -b 0.8 >/dev/null 2>&1 &
# Faster startup for GTK apps:
dbus-update-activation-environment --systemd DISPLAY WAYLAND_DISPLAY > /dev/null 2>&1 &
# Clipboard setting
wl-paste --watch cliphist store &
# seatd: graphics/input hardware access 
seat seat0 hide_cursor 3000

#########
# For external monitors, use `wlopm` to get the monitor name. Examples:
# monitorOffCommand_wayland=wlopm --off HDMI-A-1
# monitorOffCommand_wayland=wlopm --off "*"
#
# Configure output directives such as mode, position, scale and transform.
