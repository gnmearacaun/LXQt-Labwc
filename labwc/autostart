#########
# Experimental 
#########
# Hide cursor after login 
wtype -M alt -M logo h -m alt -m logo &
# for hibernate to work on my machine 
sudo swapon /swap/swapfile &
# set charging limits
echo 84 | sudo tee /sys/class/power_supply/BAT0/charge_stop_threshold &
echo 77 | sudo tee /sys/class/power_supply/BAT0/charge_start_threshold &
