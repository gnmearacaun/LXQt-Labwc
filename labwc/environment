##############
## ~/.config/labwc/environment 
## Cursor theme and size are set by LXQt and can be configured in"Appearance → Cursor".
## Uncomment lines starting with one '#' to suit your needs.
##############
## LXQt tries to set keyboard layout the first login, edit here to change and/or complete.
# XKB_DEFAULT_LAYOUT=ie
## Multiple keyboard layouts can be set by comma-separating the country codes.
## If a variant layout is needed, the syntax is layout(variant)
XKB_DEFAULT_LAYOUT=ie,gb(intl)
# XKB_DEFAULT_LAYOUT=gb,us(intl)
## If multiple layouts are used, specify a toggle-keybind 
# grp:alt_altgr_toggle Both Alts together; AltGr alone chooses third level
# grp:alts_toggle      Both Alts together
XKB_DEFAULT_OPTIONS=grp:alts_toggle,compose:ralt
# XKB_DEFAULT_OPTIONS=grp:alt_shift_toggle
# XKB_DEFAULT_OPTIONS=grp:shift_ctrl,compose:ralt
#
## For possible values of country codes, options and so on refer to 
## /usr/share/X11/xkb/rules/evdev.lst
## For further details, see xkeyboard-config(7)
##############
#
# Experimental
# Scaling for gtk apps, there is also a place to set in 
# `LXQt Session Settings > Environment`
GDK_SCALE=1.1
GDK_DPI_SCALE=1.1
